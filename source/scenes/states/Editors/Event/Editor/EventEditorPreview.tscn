[sub_resource type="GDScript" id="GDScript_gthfs"]
resource_name = "EventEditor"
script/source = "extends Node

func _unhandled_input(event: InputEvent) -> void:
	if event is InputEventKey:
		if !event.pressed or event.echo: return
		match event.keycode:
			KEY_SPACE:
				if Conductor.is_playing:
					%PlayState.process_mode = PROCESS_MODE_DISABLED
					Conductor.pauseSongs() 
				else: 
					%PlayState.process_mode = PROCESS_MODE_INHERIT
					Conductor.resumeSongs()
"

[sub_resource type="Resource" id="Resource_sa5ld"]
