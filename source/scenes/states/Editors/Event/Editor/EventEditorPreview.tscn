[sub_resource type="GDScript" id="GDScript_0jpuc"]
resource_name = "FilesManager"
script/source = "extends PopupMenu

@onready var chart_dialog = $ChartLoader
@onready var clear_popup = $ClearChart
@onready var audio_select: PopupPanel = $AudioSelect
@onready var audio_dialog: FunkinFileDialog = $AudioDialog


func _on_index_pressed(index: int) -> void:
	match index:
		0: chart_dialog.show()
		2: clear_popup.show()
		3: audio_select.show()
		4: audio_dialog.show()

func _on_chart_selected(file: String):
	var options = chart_dialog.get_selected_options()
"

[sub_resource type="GDScript" id="GDScript_wa4ne"]
resource_name = "AudioLoader"
script/source = "extends PopupPanel

@onready var inst: LineEdit = $VBoxContainer/Inst
@onready var voices: LineEdit = $VBoxContainer/Voices
@onready var bpm: ButtonRange = $VBoxContainer/BPM

var _last_dir: String = PathsStore.assetsPath
var _selecting_songs: bool = false

func _load():
	Conductor.loadSong(inst.text,&\"Inst\")
	if voices: for i in voices.text.split(\",\"): Conductor.loadSong(i,i.get_file())
	Conductor.default_bpm_data.bpm = bpm.value
	hide()

func _on_load_inst_button_down() -> void:
	var dialog = FunkinFileDialog.new()
	dialog.current_dir = _last_dir
	dialog.transient = false
	dialog.use_native_dialog = true
	dialog.file_selected.connect(
		func(text):
			inst.text = text
			_last_dir = text.get_base_dir()
			dialog.queue_free()
	)
	dialog.file_mode = FileDialog.FILE_MODE_OPEN_FILE
	dialog.visible = true
	get_window().add_child(dialog)

func _on_load_voices_button_down() -> void:
	var dialog = FunkinFileDialog.new()
	dialog.current_dir = _last_dir
	dialog.use_native_dialog = true
	dialog.files_selected.connect(func(texts):
		voices.text = \",\".join(texts)
		_last_dir = texts[0].get_base_dir()
		dialog.queue_free()
	)
	dialog.file_mode = FileDialog.FILE_MODE_OPEN_FILES
	dialog.visible = true
	get_window().add_child(dialog)

func _notification(what: int) -> void:
	match what:
		NOTIFICATION_APPLICATION_FOCUS_OUT: if visible: _selecting_songs = true; show.call_deferred()
		NOTIFICATION_APPLICATION_FOCUS_IN: 
			if _selecting_songs: _selecting_songs = false; call_deferred(\"call_deferred\",\"show\")
"

[sub_resource type="GDScript" id="GDScript_v0h7v"]
resource_name = "PreviewManager"
script/source = "extends PopupMenu


@onready var play_state = %PlayState
@onready var play_view: SubViewport = %PlayView
@onready var stage_loader: FileDialog = $StageLoader

func _on_index_pressed(index: int) -> void:
	match index:
		0: 
			if is_item_checked(0): 
				play_view.render_target_update_mode = SubViewport.UPDATE_DISABLED; 
				play_state.process_mode = Node.PROCESS_MODE_INHERIT
			else: 
				play_view.render_target_update_mode = SubViewport.UPDATE_WHEN_VISIBLE; 
				play_state.process_mode = Node.PROCESS_MODE_DISABLED
		2: stage_loader.show()
"

[sub_resource type="GDScript" id="GDScript_5wlhs"]
resource_name = "StageLoader"
script/source = "extends FunkinFileDialog

signal on_stage_loaded(stage: Dictionary)
func _on_file_selected(path: String) -> void: on_stage_loaded.emit(FunkinStage.fixStageJson(Paths.load_json_absolute(path)))
"

[sub_resource type="GDScript" id="GDScript_oj8pg"]
resource_name = "EventProperties"
script/source = "extends PanelContainer

signal event_selected(event: Dictionary)
@onready var popup: PopupPanel = $Container/Event/EventSelected/Popup
@onready var event_button: Button = $Container/Event/EventSelected

@onready var step_rect: Node2D = %StepRect
@onready var variables_menu = %VariablesMenu
@onready var trigger_player: CheckBox = $Container/TriggerPlayer
@onready var trigger_opponent: CheckBox = $Container/TriggerOpponent

var event_data: Dictionary
func _on_event_pressed(i: Button):
	var cur_event = variables_menu.cur_event_variables
	event_button.text = i.text
	event_button.icon = i.icon
	event_data = i.get_meta(&\"event_data\")
	cur_event.e = i.text
	var vars = cur_event.get(\"v\"); if vars: vars.clear()
	variables_menu.load_variables(event_data)
	trigger_opponent.set_pressed_no_signal(event_data.get(\"trigger_when_opponent\",true))
	trigger_player.set_pressed_no_signal(event_data.get(\"trigger_when_player\",true))

func _on_event_selected(event: EventKey) -> void:
	event_button.text = event.event_name
	event_data = event.event_data
	event_button.icon = event.event_data.icon_texture
	variables_menu.cur_event_variables = event.chart_data
	variables_menu.load_variables(event.event_data)
"

[sub_resource type="GDScript" id="GDScript_prnaq"]
resource_name = "EventVariables"
script/source = "@tool
extends VBoxContainer
var cur_event_variables: Dictionary[StringName, Variant] = EventNote.get_base_data()
func _on_event_selected(event: Button): load_variables(event.get_meta(&\"event_data\"))

func load_variables(event_data: Dictionary):
	for i in get_children(): i.queue_free()
	
	var vars = event_data.get(&\"variables\"); if !vars: return
	for i in vars:
		var data = vars[i]
		var type = data.get(\"type\",\"String\")
		type = MathUtils.get_type_by_name(type)
		
		if data.get(\"options\"): _create_menu_button(i ,data)
		else:
			match type:
				TYPE_STRING,TYPE_STRING_NAME: _add_line_edit_interator(i, data)
				TYPE_FLOAT,TYPE_INT: _add_button_range(i, data, type == TYPE_INT)
				TYPE_COLOR: _add_color_interator(i, data)

func set_property_value(value: Variant, property_name: StringName): cur_event_variables.v[property_name] = value
func get_property_value(property_name: StringName, default: Variant) -> Variant: 
	var vars = cur_event_variables.get(\"v\"); 
	return vars.get(property_name, default) if vars else default

func _create_property_title(prop: Control):
	var label = Label.new()
	label.name = prop.name
	label.text = prop.name+\": \"
	label.vertical_alignment = VERTICAL_ALIGNMENT_CENTER
	var line_size = Vector2(100.0,30)
	label.custom_minimum_size = Vector2(60.0,0.0) + line_size * 1.5
	
	prop.position = Vector2(label.get_minimum_size().x, line_size.y* 0.25)
	prop.size = line_size
	prop.position.x = label.get_minimum_size().x
	label.add_child(prop)
	add_child(label)
	return label

func _create_menu_button(property_name: StringName, data: Dictionary):
	var menu = MenuButton.new()
	menu.flat = false
	menu.name = property_name
	var popup = menu.get_popup()
	popup.index_pressed.connect(func(i: int): 
		menu.text = popup.get_item_text(i)
		set_property_value(menu.text,property_name) 
	)
	for i in data.options: popup.add_item(i)
	_create_property_title(menu).tooltip_text = data.get(\"description\",\"\")

func _add_button_range(property_name: StringName, data: Dictionary, is_int: bool = false):
	var range = ButtonRange.new()
	range.text = property_name+\": \"
	range.name = property_name
	range.int_value = is_int
	range.line_edit.placeholder_text = str(data.get(\"default\",\"\"))
	range.value = float(get_property_value(property_name,range.line_edit.placeholder_text))
	range.value_changed.connect(set_property_value.bind(property_name))
	range.tooltip_text = str(data.get(\"description\",\"\"))
	add_child(range)

func _add_color_interator(property_name: StringName, data: Dictionary):
	var color_picker = ColorPickerButton.new()
	color_picker.name = property_name
	color_picker.color = Color(get_property_value(property_name,\"ffffff\"))
	color_picker.color_changed.connect(func(col): set_property_value(Color.html(col),property_name))
	_create_property_title(color_picker).tooltip_text = str(data.get(\"description\",\"\"))


func _add_line_edit_interator(property_name: StringName, data: Dictionary):
	var line_edit = LineEdit.new()
	line_edit.name = property_name
	line_edit.placeholder_text = str(data.get(\"default\",\"\"))
	line_edit.text = get_property_value(property_name,\"\")
	
	line_edit.text_submitted.connect(
		func(t):
			if t: set_property_value(t, property_name)
			else: cur_event_variables.v.erase(property_name)
	)
	_create_property_title(line_edit).tooltip_text = str(data.get(\"description\",\"\"))
"

[sub_resource type="ViewportTexture" id="ViewportTexture_dx476"]
viewport_path = NodePath("PlayView")

[sub_resource type="GDScript" id="GDScript_vt33a"]
resource_name = "Timeline"
script/source = "extends Panel

var events_created: Array[Control]
var cur_event_selected: EventKey

@onready var scroll = $Scroll
@onready var chess_container = $Scroll/Chess
@onready var CHESS_SIZE: Vector2 = chess_container.get_meta(&\"chess_size\")
@onready var line = $Scroll/Line
@onready var step_rect: Node2D = %StepRect
@onready var slots_count: Label = %SlotsCount
@onready var event_property = %EventProperties
var chess_created: Array[ChessEvent]

signal event_selected(event: EventKey)
func _ready() -> void:
	_create_chess(); Conductor.song_position_changed.connect(_on_song_position_changed)

func _on_song_position_changed():
	var _step = Conductor.step_float
	var off: float 
	line.position.x = _step * CHESS_SIZE.x
	if _step < 0:   off = -24.0 * CHESS_SIZE.x
	else:   off = -maxf(_step - 12.0, 0) 
	scroll.position.x = off * CHESS_SIZE.x
	
	for i in chess_created: i.step_offset = -snappedf(off,2.0)
#region Chess Methods
func _create_chess():
	var chess = ChessEvent.new()
	chess.chess_input.connect(_on_chess_gui_input)
	chess.mouse_exited.connect(step_rect.hide)
	chess.mouse_entered.connect(step_rect.show)
	chess.rect_size = CHESS_SIZE
	chess.position.y = CHESS_SIZE.y * 2.0 * (chess_container.get_child_count())
	chess.size = Vector2(
		CHESS_SIZE.x * 27.0, 
		CHESS_SIZE.y
	)
	chess_container.add_child(chess)
	chess_created.append(chess)
	_update_slots_text()

func _on_chess_gui_input(event: InputEvent, chess: ChessEvent) -> void:
	step_rect.cur_chess = chess
	if event is InputEventMouseButton:
		if !event.pressed or event.button_index != 1: return
		var step = step_rect.position.x / chess.rect_size.x
		_create_event(step, chess)

func _update_slots_text():
	var t: String = ''
	var length = chess_container.get_child_count()
	var count = 1
	while count <= length: t += '\\n\\n%d\\n\\n' % count; count += 1
	slots_count.text = t
#endregion

#region Event Methods
func _create_event(step: float, chess: Chess):
	var event_note = EventKey.new()
	event_note.chart_data.t = Conductor.get_step_time(step)
	event_note.event_data = event_property.event_data
	event_note.position = Vector2(
		step * chess.rect_size.x, 
		chess.position.y + chess.rect_size.y * 0.5
	)
	chess_container.add_child(event_note)
	chess.get_meta(&\"events\").append(event_note)
	return event_note

func _select_event(event: EventKey):
	if cur_event_selected: _unselect_event(cur_event_selected)
	event.modulate = Color.CYAN
	event_selected.emit(event)

func _unselect_event(event: EventKey): event.modulate = Color.WHITE
#endregion


class ChessEvent extends Chess:
	var events_created: Array[Node2D]
	var event_init: int
	var event_final: int
	var step_offset: float:
		set(val):
			step_offset = val
			position.x = val * rect_size.x
	
	
	signal chess_input(event: InputEvent, chess: ChessEvent)
	func _gui_input(event: InputEvent) -> void: chess_input.emit(event,self)
	
	func _ready(): 
		primary_color = Color(0.2,0.2,0.2)
		secondary_color = Color(0.1,0.1,0.1)
		set_meta(&\"events\", []); super(); 
	
	func _validate_property(property: Dictionary) -> void:
		match StringName(property.name):
			&\"rect_size\": property.usage = PROPERTY_USAGE_NONE
"

[sub_resource type="GDScript" id="GDScript_l35mb"]
resource_name = "Steps"
script/source = "@tool
extends Node2D
const STEPS_TO_DRAW: int = 26
var bg_color: Color = Color(0.2,0.2,0.2,0.25)
var step_init: int = 0:
	set(val): 
		if step_init == val: return
		step_init = val; queue_redraw()

@export var max_steps: int = 1:
	set(val): max_steps = val; queue_redraw()

@onready var chess = $\"../Chess\"
@onready var scroll: Node2D = $\"..\"

@onready var CHESS_SIZE: Vector2 = chess.get_meta(&\"chess_size\")
func _ready() -> void:
	if Engine.is_editor_hint(): return
	Conductor.song_position_changed.connect(_update_step)
	Conductor.on_bpm_changes.connect(_on_bpm_changes)
	_on_bpm_changes()

func _update_step() -> void: step_init = floori(-scroll.position.x / CHESS_SIZE.x)
func _on_bpm_changes(): max_steps = Conductor.get_step_count()

func _draw() -> void:
	var init: int = step_init
	var steps_to_draw: int = mini(max_steps,init + STEPS_TO_DRAW)
	draw_rect(Rect2(-scroll.position.x, 0.0, CHESS_SIZE.x * (STEPS_TO_DRAW+1), 25), bg_color)
	while init <= steps_to_draw:
		draw_string(
			ThemeDB.fallback_font,
			Vector2(CHESS_SIZE.x*init,20.0),
			\"%d\" % init,
			HORIZONTAL_ALIGNMENT_CENTER,
			CHESS_SIZE.x,14
		)
		
		draw_string(
			ThemeDB.fallback_font,
			Vector2(CHESS_SIZE.x*(init+1) - 5.0,20.0),
			\"|\"
		)
		init += 1
"

[sub_resource type="GDScript" id="GDScript_tt24g"]
resource_name = "ChessStepRect"
script/source = "@tool
extends SolidNode2D

@onready var chess: Node2D = $\"../Chess\"
var cur_chess
func _process(_d: float) -> void:
	if !visible or !cur_chess: return
	var mouse_x: float = cur_chess.get_local_mouse_position().x
	if !Input.is_key_pressed(KEY_SHIFT): mouse_x = snappedf(mouse_x, cur_chess.rect_size.x)
	position.x = cur_chess.position.x + mouse_x
	position.y = cur_chess.position.y + (cur_chess.size.y - size.y)*0.5 + chess.position.y
"

