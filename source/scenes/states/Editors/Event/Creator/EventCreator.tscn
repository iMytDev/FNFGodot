[sub_resource type="GDScript" id="GDScript_wv6yg"]
resource_name = "Icon"
script/source = "extends LineEdit

func _on_icon_file_selected(path: String) -> void:
	path = PathsStore.get_base_path(path,false)
	if path.begins_with(\"images/\"): path = path.right(-7)
	text = path.get_basename(); text_submitted.emit(text)


func _on_event_loaded(data: EventData) -> void:
	text = data.icon; 
	text_submitted.emit(text)
"

[sub_resource type="GDScript" id="GDScript_hpgey"]
script/source = "extends LineEdit
func _on_event_loaded(data: EventData) -> void: text = data.description
"

[sub_resource type="GDScript" id="GDScript_laab7"]
resource_name = "VariablesContainer"
script/source = "extends Control
const VariableButton = preload(\"uid://cym5wyvu8du7u\")
@onready var container: VBoxContainer = $Container/VBoxContainer
@onready var var_name: LineEdit = $Name

func _add_variable():
	if !var_name.text: 
		Global.show_label_warning(\"Insert a name before adding it\")
		return
	
	if var_name.text in owner.event.variables:
		Global.show_label_warning(\"Property already exists with the same name!\")
		return
	var value_type = EventValueType.new()
	owner.event.variables[var_name.text] = value_type
	add_variable_from_type(var_name.text,value_type)

func add_variable_from_type(prop_name: String, data: EventValueType):
	var variable_button = VariableButton.new(data)
	variable_button.title = prop_name
	container.add_child(variable_button)
	
	var delete_button = Button.new()
	delete_button.icon = load(\"res://icons/Remove.svg\")
	delete_button.button_down.connect(func():
		owner.event.variables.erase(prop_name)
		variable_button.queue_free()
		queue_free()
	)
	delete_button.add_theme_constant_override(&\"icon_max_width\",16)
	delete_button.position.x = container.size.x - 40
	variable_button.add_child(delete_button)

func _on_event_loaded(data: EventData) -> void:
	for i in container.get_children(): i.queue_free()
	for i in data.variables: add_variable_from_type(i, data.variables[i])
"

