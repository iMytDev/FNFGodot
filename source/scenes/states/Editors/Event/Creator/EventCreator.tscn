[sub_resource type="GDScript" id="GDScript_afo8h"]
resource_name = "EventManager"
script/source = "extends Node

@export var event: EventData = EventData.new()

signal on_event_loaded(data: EventData)
func _save_event(path_absolute: String):
	var event_converted = _get_event_converted_to_json()
	var save = FileAccess.open(path_absolute,FileAccess.WRITE)
	save.store_string(JSON.stringify(event_converted,'\\t'))
	save.close()

func _load_event(path_absolute: String):
	event = EventData.load_from_json(Paths.load_json_absolute(path_absolute))
	on_event_loaded.emit(event)

func _get_event_converted_to_json() -> Dictionary:
	var dict = {
		&\"description\": event.description,
		&\"icon\": event.icon,
		&\"variables\": {}
	}
	for i in event.variables:
		var d = event.variables[i]
		var type = d.type
		var var_data: Dictionary[String, Variant] = {}
		if d.default:
			match type:
				TYPE_VECTOR2,TYPE_VECTOR2I: var_data.default = [d.default.x,d.default.y]
				TYPE_VECTOR3,TYPE_VECTOR4I: var_data.default = [d.default.x,d.default.y,d.default.z]
				TYPE_VECTOR4,TYPE_VECTOR4I: var_data.default = [d.default.x,d.default.y,d.default.z,d.default.w]
				_: var_data.default = d.default
		var_data.type = d.type_string
		dict.variables[i] = var_data
	return dict

func _on_description_submitted(new_text: String) -> void: event.description = new_text
func _on_icon_submitted(new_text: String) -> void: event.icon = new_text
"

