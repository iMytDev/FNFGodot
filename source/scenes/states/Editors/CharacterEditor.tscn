[sub_resource type="GDScript" id="GDScript_e6wko"]
script/source = "extends CheckBox

@onready var character_editor: Node = $\"../..\"

func _toggled(toggled_on: bool) -> void:
	character_editor.character_node.charType = Character.Type.BF if toggled_on else Character.Type.OPPONENT
"

