[sub_resource type="GDScript" id="GDScript_vy4m0"]
resource_name = "ChessPositions"
script/source = "extends Control; 

const CHESS_SIZE = 30.0
@onready var chess_container = $ChessManager/Chess
@onready var time_line = $TimeLine
@onready var notes_manager = $NotesManager

var offset: float
func _ready() -> void: 
	offset = position.y; 
	Conductor.song_position_changed.connect(_update_pos); _update_pos();
	resized.connect(_update_line_size); _update_size()

func _update_pos(): 
	var step: float = Conductor.step_float
	if Conductor.beat_reduced: step += Conductor.beat_reduced.cutback
	step *= CHESS_SIZE
	position.y = offset - step * scale.y; time_line.position.y = step + notes_manager.position.y

func _update_size(): size.x = chess_container.get_minimum_size().x; _update_line_size()
func _update_line_size() -> void: time_line.size.x = size.x
"

[sub_resource type="GDScript" id="GDScript_a2nyq"]
resource_name = "ChessManager"
script/source = "@tool
extends Node2D

@onready var gf_icon = $gf
@onready var gf_chess = $Chess/ChessGF
@onready var parent = $\"..\"
func _ready() -> void: Conductor.section_hit_once.connect(_on_section_hit)
func _on_section_hit(): position.y = Conductor.section * 16.0 * parent.CHESS_SIZE

func show_gf_section(_show: bool): gf_icon.visible = _show; gf_chess.visible = _show
func _validate_property(property: Dictionary) -> void:
	match StringName(property.name):
		&\"rotation\": property.usage = PROPERTY_USAGE_NONE
"

[sub_resource type="GDScript" id="GDScript_ti7k3"]
resource_name = "MouseRect"
script/source = "extends SolidNode2D

@export var chess_interatives: Array[Chess]

var CHESS_DIV: Vector2 = Vector2.ONE
var cur_chess: Chess
func _ready() -> void: for i in chess_interatives: i.gui_input.connect(_chess_input.bind(i))

func _process(_d: float) -> void: if cur_chess: _rect_follow_mouse()

func _rect_follow_mouse():
	var local_pos = cur_chess.get_local_mouse_position()
	var mouse_pos = cur_chess.position
	
	var chess_div = cur_chess.rect_size / CHESS_DIV
	var floor = (local_pos / chess_div).floor()
	var div =  (local_pos / chess_div).floor() / CHESS_DIV * cur_chess.rect_size
	
	if Input.is_key_pressed(KEY_SHIFT): mouse_pos += Vector2(div.x, local_pos.y)
	else: mouse_pos += div
	position = mouse_pos
	visible = Rect2(cur_chess.position,cur_chess.size).has_point(mouse_pos)

func _chess_input(_event: InputEvent, chess: Chess): cur_chess = chess

func _notification(what: int) -> void:
	match what:
		NOTIFICATION_WM_WINDOW_FOCUS_IN: set_process(true)
		NOTIFICATION_WM_WINDOW_FOCUS_OUT: set_process(false)
"

