[sub_resource type="GDScript" id="GDScript_tg5ha"]
resource_name = "NotesControl"
script/source = "extends Node2D
const ChartChess = preload(\"uid://bpf603wdt3lms\")
const CHESS_SIZE: Vector2 = Vector2(30.0,30.0)
var CHESS_DIV: Vector2 = Vector2(1.0,1.0)

const NOTE_SELECTED_COLOR = Color.DARK_GRAY
const NOTE_UNSELECTED_COLOR = Color.WHITE
const NoteChart = preload(\"uid://dxl7cofy02rr5\")

@export var chess_opponent: Chess
@export var chess_player: Chess
@export var chess_girlfriend: Chess
@onready var notes_group = $\"Notes\"


@onready var mouse_rect: Node2D = %MouseRect
var cur_mouse_chess: Chess

var _notes_per_section_created: Array
var _cur_note_hitted: int
var _cur_notes_section: Array[NoteChart]
var _notes_created: Array

var mustHitSection: bool
var gfSection: bool

var cur_section_data: Dictionary
var arrowStyle: StringName = SongData.DEFAULT_ARROW_STYLE
var keyCount: int = 4

var is_removing_notes: bool

var _notes_selected: Array[NoteChart]
signal on_notes_selected(note: Array[NoteChart])
signal on_note_hit(note: NoteChart)

func _init() -> void:
	if Engine.is_editor_hint(): return
	Conductor.song_loaded.connect(_on_song_loaded)
	Conductor.section_hit_once.connect(_on_section_hit_once)
	Conductor.song_position_changed.connect(_check_notes_hit)

func _on_song_loaded():
	_notes_per_section_created.resize(Conductor.songData.data.get(&\"notes\",[]).size())
	arrowStyle = Conductor.songData.getArrowStyle()
	keyCount = Conductor.songData.data.get(&\"keyCount\",4)
	if is_node_ready(): _on_section_hit_once.call_deferred()

func _ready() -> void: 
	for i in [chess_opponent,chess_player,chess_girlfriend]: if i: i.gui_input.connect(_chess_input.bind(i))
	if chess_girlfriend: chess_girlfriend.visibility_changed.connect(_update_notes_positions.call_deferred)
	_on_song_loaded()

func _on_section_hit_once() -> void:
	var length = Conductor.songData.sections.size()-1
	while length < Conductor.section:
		Conductor.songData.sections.append(FunkinChartParser.getSectionBase())
		_notes_per_section_created.append(null)
		length += 1
	
	_erase_notes()
	_spawn_notes_from_section(Conductor.section)
	if Conductor.section < length: _spawn_notes_from_section(Conductor.section + 1, true)
	
	_cur_note_hitted = 0
	_cur_notes_section = _notes_per_section_created[Conductor.section]
	cur_section_data = Conductor.get_section_data(Conductor.section)

func _process(_d: float) -> void: if _notes_selected: _process_note_selected_colors()



func _process_note_selected_colors() -> void:
	var col = Color.WEB_GRAY.lerp(Color.DIM_GRAY, sin(Time.get_ticks_msec()*0.005))
	for i in _notes_selected: i.modulate = col

#region Notes
func _add_note(note: NoteChart) -> int: notes_group.add_child(note); return _add_note_to_array(note, _notes_created)

func _add_note_to_array(note: NoteChart, array: Array) -> int:
	var i: int = array.size()
	while i:
		if array[i-1].strumTime < note.strumTime: break
		i -= 1
	array.insert(i,note)
	_update_note_position(note)
	return i

func _spawn_notes_from_section(sec: int, is_next: bool = false):
	var notes = _notes_per_section_created[sec]
	if notes == null: notes = _create_notes_from_section(sec)
	for i in notes:
		if !i.is_inside_tree(): _add_note(i);
		else: _update_note_position(i)
		i.modulate = Color.DARK_GRAY if is_next else Color.WHITE

func _update_notes_positions(): for i in _notes_created: _update_note_position(i)

func _update_note_position(note: NoteChart): 
	var note_chess = _get_note_chess(note)
	var _x = CHESS_SIZE.x * note.noteData
	if note_chess: _x += note_chess.position.x
	note.position = Vector2(_x, Conductor.get_step(note.strumTime) * CHESS_SIZE.y)

func _get_note_chess(note: NoteChart) -> Chess:
	if note.gfNote and chess_girlfriend and chess_girlfriend.visible: return chess_girlfriend
	return chess_player if note.mustPress else chess_opponent

func _create_notes_from_section(sec: int) -> Array[NoteChart]:
	var n = _notes_per_section_created[sec]; if n != null: return n
	var notes: Array[NoteChart]
	_notes_per_section_created[sec] = notes
	for i in Conductor.get_section_data(sec).get('sectionNotes',[]): _create_note_chart(i,sec)
	return notes

func _create_note_from_chess(chess: ChartChess, pos: Vector2):
	if !Conductor.bpm_data.bpm: Global.show_label_warning(\"BPM cannot be zero!\"); return
	
	var data: Dictionary
	var step = pos.y
	step += (Conductor.section * 16.0)
	if Conductor.beat_reduced: step -= Conductor.beat_reduced.cutback * 4.0
	
	data.t = Conductor.get_step_time(step)
	data.d = int(pos.x)
	
	if chess.mustPress != mustHitSection: 
		data.d += keyCount
	
	var note = _create_note_chart(data,Conductor.section)
	
	if chess.gfSection: note.gfNote = true
	var index = _add_note(note)
	
	if index <= _cur_note_hitted: _cur_note_hitted += 1
	cur_section_data.sectionNotes.insert(index,data)

func remove_note(note: NoteChart):
	_notes_created.erase(note)
	_notes_selected.erase(note)
	_notes_per_section_created[note.note_section].erase(note)
	note.section_parent.erase(note.chart_data)
	note.queue_free()

func _create_note_chart(noteData: Dictionary, sec: int) -> NoteChart: 	
	var note_chart = NoteChart.new(noteData)
	var section_data = Conductor.get_section_data(sec)
	note_chart.loadFromStyle(arrowStyle)
	note_chart.mustPress = Note.note_is_must_press(
		noteData.get('d',0),
		section_data.get(&\"mustHitSection\",false)
	)
	note_chart.stepCrochet = Conductor.bpm_data.stepCrochet
	note_chart.section_parent = section_data.sectionNotes
	note_chart.note_section = sec
	note_chart.interator.gui_input.connect(_note_gui_event.bind(note_chart))
	_add_note_to_array(note_chart,_notes_per_section_created[sec])
	return note_chart

func _erase_notes():
	for i in _notes_created: notes_group.remove_child(i)
	_notes_created.clear()

func _clear_notes():
	var i = _notes_per_section_created.size()
	while i:
		i -= 1
		var sec_data = Conductor.get_section_data(i)
		var _notes_section = _notes_per_section_created[i]
		if _notes_section != null: 
			while _notes_section: remove_note(_notes_section.pop_back())
			_notes_per_section_created[i] = null
		else: sec_data.sectionNotes.clear()
	_notes_selected.clear()
	_on_section_hit_once()

func _check_notes_hit():
	if !_cur_notes_section: return
	
	_cur_note_hitted = min(_cur_note_hitted,_cur_notes_section.size())
	while _cur_note_hitted:
		var i = _cur_notes_section[_cur_note_hitted-1]
		if i.strumTime < Conductor.songPosition: break
		i.set_meta(&\"hitted\",false)
		i.modulate = Color.WHITE
		_cur_note_hitted -= 1
	
	while _cur_note_hitted < _cur_notes_section.size():
		var i = _cur_notes_section[_cur_note_hitted]
		if i.strumTime >= Conductor.songPosition: break
		_on_note_hit(i)
		i.set_meta(&\"hitted\",true)
		_cur_note_hitted += 1

func _on_note_hit(note: NoteChart) -> void: note.modulate = Color.DARK_GRAY; on_note_hit.emit(note)

func select_note(note: NoteChart, multiple_selection: bool = false):
	if note.get_meta(&\"selected\",false): unselect_note(note, true); return
	if !multiple_selection: 
		for i in _notes_selected: unselect_note(i,false)
		_notes_selected.clear()
	_notes_selected.append(note)
	note.set_meta(&\"selected\",true)
	on_notes_selected.emit(_notes_selected);

func unselect_note(note: NoteChart, remove_from_selected_array: bool = true):
	if remove_from_selected_array: _notes_selected.erase(note)
	note.modulate = _get_note_modulate(note)
	note.set_meta(&\"selected\",false)

func _get_note_modulate(n: NoteChart): return NOTE_SELECTED_COLOR if n.get_meta(&\"hitted\",false) else NOTE_UNSELECTED_COLOR

func _note_gui_event(event: InputEvent, note: NoteChart):
	if is_removing_notes: remove_note(note); return
	if event is InputEventMouseButton:
		if !event.pressed: return
		match event.button_index:
			1: select_note(note, event.shift_pressed)
			2: remove_note(note)
#endregion


#region Chess Events
func _chess_input(event: InputEvent, chess: Chess):
	cur_mouse_chess = chess
	if event is InputEventMouseButton:
		if !event.pressed or event.button_index != 1: return
		_create_note_from_chess(chess, (mouse_rect.position - chess.position) / CHESS_SIZE)
#endregion

func _input(event: InputEvent) -> void:
	if event is InputEventMouseButton:
		if event.button_index == 2: is_removing_notes = event.pressed

func _unhandled_input(event: InputEvent) -> void:
	if event is InputEventKey:
		if !event.pressed: return
		match event.keycode:
			KEY_LEFT: if CHESS_DIV.y > 1.0: CHESS_DIV.y -= 1.0
			KEY_RIGHT: if CHESS_DIV.y < 5.0: CHESS_DIV.y += 1.0
"

[sub_resource type="GDScript" id="GDScript_7u5q8"]
resource_name = "StrumsManager"
script/source = "extends Node2D

@onready var parent = $\"..\"
var strums_created: Array[StrumNote]
var _strums_sustains: Array[StrumNote]

func _on_show_strums_toggled(toggled_on: bool) -> void:
	if toggled_on: _create_strums()
	else: _erase_strums()

func _ready() -> void: Conductor.song_position_changed.connect(_update_pos); Conductor.step_hit.connect(_on_step_hit)

func _erase_strums():
	for i in strums_created: i.queue_free()
	_strums_sustains.clear(); strums_created.clear()

func _create_strums():
	_erase_strums()
	for c in parent.chess_array:
		if !c.visible: continue
		for i in Conductor.songData.data.get(&\"keyCount\",4):
			var strum = StrumNote.new(i)
			strum.loadFromStyle(parent.arrowStyle)
			var _off: Vector2 = (parent.CHESS_SIZE / (strum.pivot_offset*2.0))
			var _max_value = _off[_off.max_axis_index()]
			strum.image.scale = Vector2(_max_value,_max_value)
			strum.position.x = parent.CHESS_SIZE.x * i + c.position.x
			strums_created.append(strum)
			add_child(strum)

func _update_pos(): position.y = parent.CHESS_SIZE.y * Conductor.step_float

func _on_step_hit():
	if !_strums_sustains: return
	var i = _strums_sustains.size()
	while i: 
		i -= 1
		var strum = _strums_sustains[i]
		var time = strum.get_meta(&\"sustain_time\",0.0)
		var end = strum.get_meta(&\"sustain_end\")
		if time > Conductor.songPosition or Conductor.songPosition >= end:
			strum.strumConfirm(); _strums_sustains.remove_at(i); continue
		strum.animation.play(&\"confirm\",true)

func _on_notes_manager_on_note_hit(note: Node2D) -> void:
	if !Conductor.is_playing: return
	
	var id = note.noteData
	if note.gfNote: id += Conductor.songData.keyCount*2
	elif note.mustPress: id += Conductor.songData.keyCount
	
	
	if id < strums_created.size(): 
		var strum = strums_created[id]
		if note.sustainLength: 
			strum.set_meta(&\"sustain_time\",note.strumTime)
			strum.set_meta(&\"sustain_end\",note.strumTime+note.sustainLength)
			_strums_sustains.append(strum)
			strum.animation.play(&\"confirm\")
		else: strum.strumConfirm()
"

[sub_resource type="GDScript" id="GDScript_lre2i"]
resource_name = "EventsManager"
script/source = "extends Node2D
const CHESS_SIZE = Vector2(30,30)


var event_index: int = 0
var events_loaded: Array[EventChart]
var events_showed: Array[EventChart]
@export var events_menu: MenuButton
var events: Dictionary = {}

var section_time: float = 0.0
var section_end_time: float = 0.0

func _ready() -> void:
	Conductor.section_hit_once.connect(_on_section_hit) 
	_refresh_events_menu()

func _refresh_events_menu():
	if !events_menu: return
	var popup = events_menu.get_popup()
	DynamicFileMenuButton.add_items_from_dir(events_menu.get_popup(),\"custom_events\",\"json\")
	
	popup.add_separator(\"2D\")
	DynamicFileMenuButton.add_items_from_dir(events_menu.get_popup(),\"custom_events/2d\",\"json\")
	
	popup.add_separator(\"3D\")
	DynamicFileMenuButton.add_items_from_dir(events_menu.get_popup(),\"custom_events/3d\",\"json\")

func _on_section_hit():
	section_time = Conductor.get_section(Conductor.section)
	section_end_time = Conductor.get_section(Conductor.section+2)
	_show_events()

func _show_events():
	for i in events_loaded: remove_child(i)
	events_loaded.clear()
	
	if !events_showed: return
	while event_index:
		var i = events_loaded[event_index-1]
		if i.strumTime > section_time: break
		event_index -= 1
		_show_event(i)
	
	var length = events_loaded.size()
	while event_index < length:
		var i = events_loaded[event_index+1]
		if i.strumTime >= section_end_time: break
		event_index += 1
		_show_event(i)


func _show_event(event: EventChart) -> void:
	events_loaded.append(event); add_child(event)

func _create_event():
	pass

func _remove_event(event: EventChart): pass

func _event_gui_input(event: InputEvent, _chess: Chess):
	if event is InputEventMouseButton:
		match event.button_index:
			1: print((event.position / CHESS_SIZE).floor())


class EventChart extends Sprite2D:
	var interator: Control = Control.new()
	var strumTime: float
	var data: Dictionary
	func _init() -> void:
		texture_changed.connect(
			func():
				if !texture: return
				scale = texture.get_size() / CHESS_SIZE
				interator.size = CHESS_SIZE / scale
		)
		add_child(interator)
		
	
"

[sub_resource type="GDScript" id="GDScript_rgpvr"]
script/source = "extends PopupMenu

@onready var dialog: FunkinFileDialog = %FunkinFileDialog
@onready var clear_chart_popup = $ClearChart
@onready var submenu = $SetMod

func _ready() -> void: set_item_submenu_node(2,submenu)
func _on_index_pressed(index: int) -> void:
	match index:
		0: 
			dialog.add_filter(\"*.json\")
			dialog.show()
			dialog.file_mode = FileDialog.FILE_MODE_SAVE_FILE
			dialog.file_selected.connect(func(file):Paths.saveFile(Conductor.songData.data,file))
		1: 
			dialog.file_mode = FileDialog.FILE_MODE_OPEN_FILE
			dialog.add_filter(\"*.json\")
			dialog.show()
			dialog.file_selected.connect(func(file): 
				Conductor.loadSongFromData(SongData.load_from_json(file))
			)
		2: 
			clear_chart_popup.call_deferred(\"show\")
"

[sub_resource type="GDScript" id="GDScript_31rpt"]
resource_name = "Mods"
script/source = "extends PopupMenu


signal on_mod_selected(mod: String)
func _ready() -> void: 
	add_item(\"None\")
	for i in PathsStore.get_mods_enabled(): add_item(i)


func _on_index_pressed(index: int) -> void: 
	var mod = get_item_text(index) if index > 0 else ''
	PathsStore.curMod = mod
	Conductor.songData.mod = PathsStore.curMod
	on_mod_selected.emit(mod)
"

[sub_resource type="GDScript" id="GDScript_753ln"]
resource_name = "AudioFile"
script/source = "extends PopupMenu


@onready var dialog: FunkinFileDialog = %FunkinFileDialog
func _on_index_pressed(index: int) -> void:
	match index:
		0:
			dialog.file_mode = FileDialog.FILE_MODE_OPEN_FILE
			dialog.add_filter(\"*.ogg\")
			dialog.add_filter(\"*.mp3\")
			dialog.add_filter(\"*.wav\")
			dialog.show()
			dialog.file_selected.connect(func(file):
				Conductor.loadSong(file,\"Inst\"), CONNECT_ONE_SHOT
			)
		1:
			dialog.file_mode = FileDialog.FILE_MODE_OPEN_FILE
			dialog.add_filter(\"*.ogg\")
			dialog.add_filter(\"*.mp3\")
			dialog.add_filter(\"*.wav\")
			dialog.show()
			dialog.file_selected.connect(func(file):
				Conductor.loadSong(file,\"Voice\")
				, CONNECT_ONE_SHOT
			)
"

[sub_resource type="GDScript" id="GDScript_8p7vw"]
resource_name = "HelpDialog"
script/source = "extends PopupMenu


@onready var note_shortcuts: PopupPanel = $NoteShortcuts
func _on_index_pressed(index: int) -> void:
	match index:
		0: note_shortcuts.show()
"

[sub_resource type="GDScript" id="GDScript_ivd3g"]
resource_name = "SectionInfo"
script/source = "extends Label


@onready var must_hit_section: CheckBox = $VBoxContainer/MustHitSection
@onready var gf_section: CheckBox = $VBoxContainer/GFSection
@onready var alt_section: CheckBox = $VBoxContainer/AltSection

@onready var section_beats = $VBoxContainer/SectionBeats
var cur_sec_data: Dictionary
func _ready() -> void:
	Conductor.section_hit_once.connect(_on_section_hit)

func _on_section_hit():
	cur_sec_data = Conductor.get_section_data(Conductor.section)
	must_hit_section.set_pressed_no_signal(cur_sec_data.get(&\"mustHitSection\",false))
	gf_section.set_pressed_no_signal(cur_sec_data.get(&\"gfSection\",false))
	alt_section.set_pressed_no_signal(cur_sec_data.get(&\"alt_section\",false))
	section_beats.set_value_no_signal(cur_sec_data.get(&\"section_beats\",4.0))

func _on_must_hit_section_toggled(toggled_on: bool) -> void: cur_sec_data.mustHitSection = toggled_on
func _on_gf_section_toggled(toggled_on: bool) -> void: cur_sec_data.gfSection = toggled_on
func _on_alt_section_toggled(toggled_on: bool) -> void: cur_sec_data.altAnim = toggled_on
"

[sub_resource type="GDScript" id="GDScript_hjguf"]
resource_name = "NoteEditor"
script/source = "extends Label


@onready var note_type = $\"NoteType\"
@onready var note_sustain = $\"Sustain\"

var cur_notes_selected: Array

func _ready() -> void:
	Conductor.on_bpm_changes.connect(update_bpm)
	update_bpm()

func update_bpm(): note_sustain.step = Conductor.bpm_data.stepCrochet

func _on_notes_selected(notes: Array):
	cur_notes_selected = notes
	if !notes: reset_properties(); return
	var note = notes.back(); if !note: reset_properties(); return
	note_sustain.set_value_no_signal(note.sustainLength)
	note_type.text = note.noteType

func reset_properties():
	note_type.text = ''
	note_sustain.set_value_no_signal(0.0)

func _on_sustain_value_added(value: float) -> void:
	for i in cur_notes_selected: if i: i.sustainLength = maxf(i.sustainLength + value,0.0)


func _on_gf_note_toggled(toggled_on: bool) -> void:
	for i in cur_notes_selected: if i: i.gfNote = toggled_on; print(toggled_on)
"

[sub_resource type="GDScript" id="GDScript_ktl22"]
resource_name = "SongManager"
script/source = "extends Label

@onready var bpm = $BPM
@onready var player: DynamicFileMenuButton = $player
@onready var opponent: DynamicFileMenuButton = $opponent
@onready var girlfriend: DynamicFileMenuButton = $girlfriend
@onready var stage: DynamicFileMenuButton = $stage


func _ready() -> void:
	Conductor.song_loaded.connect(_load_song_data)
	player.popup.index_pressed.connect(_on_player_selected)
	opponent.popup.index_pressed.connect(_on_opponent_selected)
	girlfriend.popup.index_pressed.connect(_on_gf_selected)
	stage.popup.index_pressed.connect(_on_stage_selected)
	_load_song_data()

func _load_song_data(): 
	bpm.set_value_no_signal(Conductor.default_bpm_data.bpm)
	stage.text = Conductor.songData.data.get(\"stage\",\"\")
	player.text = Conductor.songData.data.get(\"player1\",\"bf\")
	opponent.text = Conductor.songData.data.get(\"player2\",\"bf\")
	girlfriend.text = Conductor.songData.data.get(\"gfversion\",\"bf\")

func _on_bpm_value_changed(value: float) -> void:
	Conductor.default_bpm_data.bpm = value
	Conductor.songData.data.bpm = value

func _on_player_selected(i: int): 
	player.text = player.popup.get_item_text(i); Conductor.songData.data.player1 = player.text
func _on_opponent_selected(i: int): 
	opponent.text = opponent.popup.get_item_text(i); Conductor.songData.data.player2 = opponent.text
	
func _on_gf_selected(i: int): 
	girlfriend.text = girlfriend.popup.get_item_text(i); 
	Conductor.songData.data.gfVersion = girlfriend.text
func _on_stage_selected(i: int): 
	stage.text = stage.popup.get_item_text(i); Conductor.songData.data.stage = stage.text
"

