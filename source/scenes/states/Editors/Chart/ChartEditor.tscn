[sub_resource type="GDScript" id="GDScript_dn6nv"]
resource_name = "ChartEditor"
script/source = "@tool
extends Node

static var song_position: float
@export var song_data: SongData = SongData.new():
	set(val): song_data = val; song_position = 0.0;


func _ready() -> void:
	if Engine.is_editor_hint(): return
	_load_song_data(); Conductor.seek(song_position)

func _update_rich_presence():
	if !DiscordRPC.get_is_discord_working(): return
	DiscordRPC.details = 'Chart Editor'
	DiscordRPC.state = 'Idle'
	if Conductor.songData.json: DiscordRPC.state = 'Editing: '+Conductor.songData.json.get_file()
	DiscordRPC.refresh()

func _load_song_data():
	if !song_data: _update_rich_presence(); return
	PathsStore.curMod = song_data.mod
	Conductor.loadSongFromData(song_data)
	_update_rich_presence()

func _get_round_step(f: float): return roundf(f / Conductor.bpm_data.stepCrochet) * Conductor.bpm_data.stepCrochet

func _enter_song():
	if !song_data.packedScene: return
	song_position = Conductor.songPosition
	process_mode = Node.PROCESS_MODE_DISABLED
	Conductor.pauseSongs()
	Global.doTransition().finished.connect(func():
		var state = load(song_data.packedScene); if !state: return
		Global.swapTree(state.new(song_data),false)
		Conductor.seek(0.0)
	)

func _unhandled_input(event: InputEvent) -> void:
	if event is InputEventKey:
		if !event.pressed: return
		match event.keycode:
			KEY_SPACE: 
				if Conductor.is_playing: Conductor.pauseSongs()
				else: Conductor.resumeSongs()
			
			#region Sections
			KEY_A:
				var sub = 4 if event.shift_pressed else 1
				Conductor.seek(Conductor.get_section_time(Conductor.section-sub))
			KEY_D:
				var add = 4 if event.shift_pressed else 1
				Conductor.seek(Conductor.get_section_time(Conductor.section+add))
			
			KEY_ENTER: _enter_song()
			#endregion
	
	elif event is InputEventMouseButton:
		match event.button_index:
			4: Conductor.seek(_get_round_step(
					maxf(0.0,Conductor.songPosition - Conductor.bpm_data.stepCrochet))
				)
			5: Conductor.seek(
				_get_round_step(maxf(0.0,Conductor.songPosition + Conductor.bpm_data.stepCrochet))
				)
"

