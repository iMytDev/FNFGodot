[sub_resource type="GDScript" id="GDScript_1e7n0"]
script/source = "@tool
extends Node3D

@export var move_lamp: bool = true:
	set(val):
		move_lamp = val
		if val: _check_lamp()
		else: rotation = _init_rotation
	
var _init_rotation: Vector3
func _ready() -> void: if move_lamp: _check_lamp()

func _check_lamp():
	if !is_node_ready(): return
	_init_rotation = rotation

func _process(_d) -> void:
	if !move_lamp: return
	rotation.x = _init_rotation.x + sin(Time.get_ticks_msec()*0.003)*0.05
	rotation.z = _init_rotation.z + cos(Time.get_ticks_msec()*0.0015)*0.05
"

