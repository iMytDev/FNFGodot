; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Friday Night Funkin' Godot"
config/version="0.2.5"
config/tags=PackedStringArray("2d", "modding", "rhythm")
run/main_scene="uid://d38t3n5h1bcw"
config/features=PackedStringArray("4.7", "GL Compatibility")
run/max_fps=240
boot_splash/stretch_mode=0
config/icon="res://icon.png"

[audio]

buses/default_bus_layout="uid://djw6qsfavpa73"

[autoload]

InputUtils="*res://source/utils/InputUtils.gd"
Conductor="*res://source/backend/Conductor/Conductor.gd"
AnimationService="*res://source/utils/animation/AnimationService.gd"
TweenService="*res://source/gdscript/Tween/TweenService.gd"
Discord="*res://source/backend/Discord.gd"
Global="*res://source/autoload/Global.gd"
FunkinParallax="*uid://c46h3k11hth1q"
SceneManager="*uid://bua5014div7cv"

[debug]

file_logging/enable_file_logging.pc=false
settings/gdscript/max_call_stack=512
gdscript/warnings/unused_signal=0
gdscript/warnings/shadowed_variable=0
gdscript/warnings/shadowed_variable_base_class=0
gdscript/warnings/shadowed_global_identifier=0
gdscript/warnings/static_called_on_instance=0
gdscript/warnings/missing_tool=0
gdscript/warnings/integer_division=0
gdscript/warnings/deprecated_keyword=0
gdscript/warnings/confusable_local_usage=0
gdscript/warnings/native_method_override=1
shader_language/warnings/enable=false
canvas_items/debug_redraw_time=0.5

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="keep_height"
window/vsync/vsync_mode=0

[dotnet]

project/assembly_name="Friday Night Funkin- Godot"

[editor_plugins]

enabled=PackedStringArray("res://addons/discord-rpc-gd/plugin.cfg")

[file_customization]

folder_colors={
"res://source/gdscript/": "green"
}

[gui]

theme/custom_font="uid://dd562b358n3k0"

[importer_defaults]

texture={
"compress/channel_pack": 1,
"compress/hdr_compression": 1,
"compress/high_quality": false,
"compress/lossy_quality": 1.0,
"compress/mode": 0,
"compress/normal_map": 1,
"detect_3d/compress_to": 0,
"editor/convert_colors_with_editor_theme": false,
"editor/scale_with_editor_scale": false,
"mipmaps/generate": true,
"mipmaps/limit": -1,
"process/fix_alpha_border": true,
"process/hdr_as_srgb": false,
"process/hdr_clamp_exposure": false,
"process/normal_map_invert_y": false,
"process/premult_alpha": false,
"process/size_limit": 0,
"roughness/mode": 1,
"roughness/src_normal": "",
"svg/scale": 1.0
}

[input]

ui_accept={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":0,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":4194309,"physical_keycode":0,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
, Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":0,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":4194310,"physical_keycode":0,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
]
}
ui_cancel={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":0,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":4194305,"physical_keycode":0,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
, Object(InputEventJoypadButton,"resource_local_to_scene":false,"resource_name":"","device":-1,"button_index":4,"pressure":0.0,"pressed":false,"script":null)
]
}

[input_devices]

pointing/emulate_touch_from_mouse=true

[physics]

2d/run_on_separate_thread=true

[rendering]

textures/vram_compression/import_s3tc_bptc=true
textures/vram_compression/import_etc2_astc=true
environment/glow/upscale_mode=0
environment/defaults/default_clear_color=Color(0.005084558, 0.005084162, 0.011245842, 1)
